<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- App title -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fall Detection"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Continuous monitoring with smart alerts"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginBottom="24dp" />

        <!-- Profile / emergency contact summary card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emergency Profile"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/profileSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Not configured"
                android:textSize="14sp"
                android:textColor="#424242"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnEditSetup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Details" />
        </LinearLayout>

        <!-- Monitoring status + controls card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Service stopped"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:layout_marginBottom="16dp" />

            <Switch
                android:id="@+id/switchAdaptive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enable adaptive sampling (battery saver)"
                android:textColor="#424242"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnStart"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Start Monitoring" />

                <Button
                    android:id="@+id/btnStop"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stop"
                    android:layout_marginStart="12dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Pending fall alert banner -->
        <LinearLayout
            android:id="@+id/alertBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#FFF3E0"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Possible fall detected"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E65100"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/alertCountdownText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sending alert in 15s..."
                android:textSize="14sp"
                android:textColor="#E65100"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnCancelAlert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel Alert" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>